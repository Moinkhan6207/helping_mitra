# Server Configuration
PORT=
NODE_ENV=

# Database Connection (PostgreSQL)
DATABASE_URL=

# CORS Settings
FRONTEND_URL=
CORS_ORIGIN=

# Authentication Secrets (JWT)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=
JWT_REFRESH_EXPIRES_IN=
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_MOBILE=
ADMIN_PASSWORD=

# PhonePe PG Integration
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=
PHONEPE_BASE_URL=

# Firebase Config (Admin SDK)
# For production: Generate a service account private key file in the Firebase Console (Project Settings -> Service Accounts).
# For local mock/sandbox testing: Provide any value starting with "mock_" (e.g. mock_project_id) to run in mock mode.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Make sure to replace any newline characters in the private key with literal '\n' if stored in a single line.
FIREBASE_PRIVATE_KEY=
# Format: <project-id>.appspot.com or storage bucket domain name
FIREBASE_STORAGE_BUCKET=
FIREBASE_MOCK_MODE=false

# Middleware Security Settings
RATE_LIMIT_WINDOW_MS=
RATE_LIMIT_MAX=
