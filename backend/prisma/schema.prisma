generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Minimal system model to allow Prisma Client generation and database connection tests
model DatabaseCheck {
  id        String   @id @default(uuid())
  checkedAt DateTime @default(now())
}

// ==========================================
// DATABASE ENUMS
// ==========================================

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum UserType {
  RETAILER
  DISTRIBUTOR
  MASTER_DISTRIBUTOR
}

// ==========================================
// DATABASE MODELS & SECURITY POLICIES
// ==========================================

/// Represents a user within the Helping Mitra platform.
/// 
/// --- SECURITY NOTE & KYC PROTECTION ---
/// 1. Password Hashing:
///    - `passwordHash` must be generated using a secure hashing algorithm (such as Argon2id or bcrypt).
///    - Plaintext passwords must never be stored.
/// 
/// 2. KYC Protection & Masking Strategy:
///    - `aadhaarNumber` and `panNumber` are highly sensitive PII (Personally Identifiable Information).
///    - These fields MUST NEVER be returned directly in API responses to avoid accidental leakage.
///    - Future Masking Strategy:
///      * Aadhaar: Display only the last 4 digits (e.g., "XXXX-XXXX-1234").
///      * PAN: Display first 2 and last 2 characters masked (e.g., "ABXXX-XX12C" or show only last 4 "XXXXXX1234").
///      * Implementation should use a custom Express response serializer/interceptor or Prisma middleware / extension to strip or mask these fields automatically.
///      * At-rest encryption (e.g. pg_crypto or application-level encryption) is highly recommended before writing to these columns.
model User {
  id            String         @id @default(uuid())
  name          String
  mobile        String         @unique
  email         String         @unique
  passwordHash  String
  role          Role           @default(USER)
  status        UserStatus     @default(ACTIVE)
  userType      UserType?      // Nullable for ADMIN users
  shopName      String?        // Nullable for ADMIN users
  aadhaarNumber String?        // Nullable for ADMIN users
  panNumber     String?        // Nullable for ADMIN users
  address       String?        // Nullable for ADMIN users
  state         String?        // Nullable for ADMIN users
  district      String?        // Nullable for ADMIN users
  pinCode       String?        // Nullable for ADMIN users
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  priceHistories ServicePriceHistory[]
  wallet          Wallet?
  orders          Order[]
  recharges       WalletRecharge[]                 @relation("UserRecharges")
  submissions     RechargeVerificationSubmission[] @relation("SubmittedSubmissions")
  auditLogs       RechargeAuditLog[]               @relation("PerformedAuditLogs")

  // Indexes for high performance searches
  @@index([email])
  @@index([mobile])
  @@index([role])
  @@index([status])
  @@index([userType])
}

/// Represents a refresh token session for a user.
///
/// --- SECURITY NOTE ---
/// 1. Token Hashing:
///    - `tokenHash` stores a secure hash (e.g., SHA-256) of the actual raw refresh token issued to the client.
///    - Do not store raw tokens in the database to prevent exploitation in case of database leakage.
/// 2. Audit Trail:
///    - `ipAddress` and `userAgent` are tracked to detect session hijacking or unusual login locations.
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime? // Nullable. A non-null timestamp indicates token is revoked.
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([expiresAt])
}

// ==========================================
// SERVICE CATALOGUE ENUMS
// ==========================================

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
}

enum ResultType {
  FILE_UPLOAD
  STATUS_ONLY
  TEXT_RESULT
}

enum ServiceFieldType {
  TEXT
  NUMBER
  DATE
  EMAIL
  MOBILE
  TEXTAREA
  SELECT
}

// ==========================================
// SERVICE CATALOGUE MODELS
// ==========================================

model ServiceCategory {
  id           String         @id @default(uuid())
  name         String
  slug         String         @unique
  description  String?        @db.Text
  status       CategoryStatus @default(ACTIVE)
  displayOrder Int
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  services     Service[]

  @@index([slug])
  @@index([status])
  @@index([displayOrder])
}

model Service {
  id                   String                       @id @default(uuid())
  categoryId           String
  name                 String
  slug                 String                       @unique
  shortDescription     String
  description          String                       @db.Text
  mrp                  Decimal                      @db.Decimal(10, 2)
  resultType           ResultType
  resultLabel          String
  status               ServiceStatus                @default(ACTIVE)
  displayOrder         Int
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
  category             ServiceCategory              @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  fields               ServiceField[]
  documentRequirements ServiceDocumentRequirement[]
  priceHistories       ServicePriceHistory[]
  orders               Order[]

  @@index([slug])
  @@index([categoryId])
  @@index([status])
  @@index([displayOrder])
  @@index([resultType])
}

model ServiceField {
  id              String           @id @default(uuid())
  serviceId       String
  label           String
  fieldKey        String
  fieldType       ServiceFieldType
  placeholder     String?
  isRequired      Boolean          @default(true)
  validationRules Json?
  sectionName     String?
  displayOrder    Int
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  service         Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, fieldKey])
  @@index([serviceId])
  @@index([displayOrder])
}

model ServiceDocumentRequirement {
  id               String   @id @default(uuid())
  serviceId        String
  documentName     String
  documentKey      String
  isRequired       Boolean  @default(true)
  allowedFileTypes String[]
  displayOrder     Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  service          Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, documentKey])
  @@index([serviceId])
  @@index([displayOrder])
}

model ServicePriceHistory {
  id               String   @id @default(uuid())
  serviceId        String
  oldMrp           Decimal  @db.Decimal(10, 2)
  newMrp           Decimal  @db.Decimal(10, 2)
  changedByAdminId String
  createdAt        DateTime @default(now())
  service          Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  changedByAdmin   User     @relation(fields: [changedByAdminId], references: [id], onDelete: Restrict)

  @@index([serviceId])
  @@index([changedByAdminId])
}

// ==========================================
// WALLET & TRANSACTION MODELS & ENUMS
// ==========================================

enum RechargeStatus {
  CREATED
  PAYMENT_INITIATED
  VERIFICATION_PENDING
  UNDER_REVIEW
  BALANCE_CREDITED
  REJECTED
  EXPIRED
  CANCELLED
}

enum WalletLedgerType {
  DEBIT
  CREDIT
  REFUND
  ADJUSTMENT
}

enum WalletReferenceType {
  ORDER
  RECHARGE
  REFUND
  ADJUSTMENT
}

enum LedgerStatus {
  COMPLETED
  REVERSED
}

enum RechargeAuditAction {
  RECHARGE_CREATED
  PAYMENT_INITIATED
  VERIFICATION_SUBMITTED
  REVIEW_STARTED
  APPROVED
  REJECTED
  RESUBMITTED
  EXPIRED
  CANCELLED
}

model Wallet {
  id           String         @id @default(uuid())
  userId       String         @unique
  balancePaise Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledgers      WalletLedger[]
}

model WalletLedger {
  id                 String              @id @default(uuid())
  walletId           String
  amountPaise        Int
  type               WalletLedgerType
  balanceBeforePaise Int
  balanceAfterPaise  Int
  referenceType      WalletReferenceType
  referenceId        String
  status             LedgerStatus        @default(COMPLETED)
  remarks            String
  createdAt          DateTime            @default(now())
  wallet             Wallet              @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@unique([referenceType, referenceId, type])
  @@index([walletId])
  @@index([createdAt])
}

model WalletRecharge {
  id                     String                           @id @default(uuid())
  rechargeNumber         String                           @unique
  userId                 String
  requestedAmountPaise   Int
  upiAccountId           String?
  upiVpaSnapshot         String?
  payeeNameSnapshot      String?
  paymentNote            String?
  status                 RechargeStatus                   @default(CREATED)
  paymentExpiresAt       DateTime?
  utrSubmissionDeadline  DateTime?
  submittedAt            DateTime?
  reviewStartedByAdminId String?
  reviewStartedAt        DateTime?
  resolvedByAdminId      String?
  resolvedAt             DateTime?
  verifiedAmountPaise    Int?
  paymentDate            DateTime?
  receivingAccountId     String?
  adminRemarks           String?
  rejectionReason        String?
  creditedAt             DateTime?
  resubmissionCount      Int                              @default(0)
  createdAt              DateTime                         @default(now())
  updatedAt              DateTime                         @updatedAt

  user                   User                             @relation("UserRecharges", fields: [userId], references: [id], onDelete: Cascade)
  submissions            RechargeVerificationSubmission[]
  auditLogs              RechargeAuditLog[]

  @@index([rechargeNumber])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([submittedAt])
  @@index([resolvedAt])
  @@index([creditedAt])
}

model RechargeVerificationSubmission {
  id                String         @id @default(uuid())
  rechargeId        String
  submissionNumber  Int
  utr               String         @unique
  proofStoragePath  String?
  submittedByUserId String
  submittedAt       DateTime       @default(now())
  status            RechargeStatus
  adminRemarks      String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  recharge          WalletRecharge @relation(fields: [rechargeId], references: [id], onDelete: Cascade)
  submittedByUser   User           @relation("SubmittedSubmissions", fields: [submittedByUserId], references: [id], onDelete: Cascade)

  @@unique([rechargeId, submissionNumber])
  @@index([rechargeId])
  @@index([submittedAt])
  @@index([utr])
}

model RechargeAuditLog {
  id                 String              @id @default(uuid())
  rechargeId         String
  action             RechargeAuditAction
  oldStatus          RechargeStatus?
  newStatus          RechargeStatus
  performedByUserId  String?
  performedByAdminId String?
  remarks            String?
  metadata           Json?
  createdAt          DateTime            @default(now())

  recharge           WalletRecharge      @relation(fields: [rechargeId], references: [id], onDelete: Cascade)
  performedByUser    User?               @relation("PerformedAuditLogs", fields: [performedByUserId], references: [id], onDelete: SetNull)

  @@index([rechargeId])
  @@index([createdAt])
}

// ==========================================
// ORDER MODELS
// ==========================================

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
  CANCELLED
}

enum PaymentStatus {
  PAID
  REFUNDED
}

enum PaymentMode {
  WALLET
}

model Order {
  id                   String            @id @default(uuid())
  orderNumber          String            @unique
  userId               String
  serviceId            String
  serviceNameSnapshot  String
  categoryNameSnapshot String
  orderAmount          Decimal           @db.Decimal(10, 2)
  paymentMode          PaymentMode       @default(WALLET)
  paymentStatus        PaymentStatus     @default(PAID)
  orderStatus          OrderStatus       @default(PENDING)
  idempotencyKey       String            @unique
  consentAccepted      Boolean
  consentAcceptedAt    DateTime
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  service              Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  fieldValues          OrderFieldValue[]
  documents            OrderDocument[]

  @@index([userId])
  @@index([serviceId])
  @@index([orderStatus])
  @@index([createdAt])
}

model OrderFieldValue {
  id          String   @id @default(uuid())
  orderId     String
  fieldKey    String
  fieldLabel  String
  fieldValue  String
  isSensitive Boolean  @default(false)
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, fieldKey])
  @@index([orderId])
}

model OrderDocument {
  id           String   @id @default(uuid())
  orderId      String
  documentKey  String
  documentName String
  fileName     String
  fileType     String
  fileSize     Int
  storagePath  String
  createdAt    DateTime @default(now())
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, documentKey])
  @@index([orderId])
}


